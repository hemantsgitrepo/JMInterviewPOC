# Copy to .env and fill in with your own values — never commit the real .env file.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
CARTESIA_API_KEY=sk_car_your_cartesia_key
# Public hostname (no scheme) that Twilio can reach, e.g. your ngrok domain or Render URL:
PUBLIC_HOST=your-subdomain.ngrok-free.app
# Shared login for the UI/API (Twilio's own webhooks are exempt). Leave both unset to
# disable auth entirely, e.g. for local dev.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
# Admin password for the Settings section (provider/model/prompt changes). Enforced only
# when set — leave unset for local dev, mirroring BASIC_AUTH behavior.
ADMIN_PASS=
# Optional: LangSmith tracing (observability only, off by default — no cost, no import,
# no wrapping when unset/false).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=jminterviewpoc
