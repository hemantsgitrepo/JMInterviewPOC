# Copy to .env and fill in with your own values — never commit the real .env file.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
CARTESIA_API_KEY=sk_car_your_cartesia_key
# Public hostname (no scheme) that Twilio can reach, e.g. your ngrok domain or Render URL:
PUBLIC_HOST=your-subdomain.ngrok-free.app
